# Copy to .env (gitignored) and fill in values.
# Existing shell env vars take precedence over file values.

# Operator-supplied encryption key for the Railgun SDK wallet store.
HERMETIC_RAILGUN_ENCRYPTION_KEY=

# 12/24-word Railgun mnemonic. Only needed for `wallet import`.
HERMETIC_RAILGUN_MNEMONIC=

# Hex private key for the public gas-payer EOA. Alternative to --ledger.
HERMETIC_PRIVATE_KEY=
